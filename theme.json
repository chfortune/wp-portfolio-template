{
	"$schema": "https://schemas.wp.org/wp/6.3/theme.json",
	"version": 2,
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
					"slug": "system-font",
					"name": "System Font"
				}
			],
			"fontSizes": [
				{
					"size": "0.875rem",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "1rem",
					"slug": "normal",
					"name": "Normal"
				},
				{
					"size": "1.25rem",
					"slug": "large",
					"name": "Large"
				},
				{
					"size": "1.5rem",
					"slug": "x-large",
					"name": "Extra Large"
				},
				{
					"size": "2rem",
					"slug": "xx-large",
					"name": "2XL"
				}
			]
		},
		"color": {
			"palette": [
				{
					"color": "#0073aa",
					"name": "Primary Blue",
					"slug": "primary-blue"
				},
				{
					"color": "#005a87",
					"name": "Primary Dark",
					"slug": "primary-dark"
				},
				{
					"color": "#1a1a1a",
					"name": "Dark",
					"slug": "dark"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#f9f9f9",
					"name": "Light Gray",
					"slug": "light-gray"
				},
				{
					"color": "#e0e0e0",
					"name": "Gray",
					"slug": "gray"
				}
			]
		},
		"spacing": {
			"spacingScale": {
				"increment": "0.5rem",
				"steps": 20
			}
		}
		
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-font)",
			"fontSize": "1rem",
			"lineHeight": 1.6
		},
		"color": {
			"background": "#ffffff",
			"text": "#1a1a1a"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": 1.2
				}
			},
			"link": {
				"color": {
					"text": "#0073aa"
				}
			}
			
		}
	}
}